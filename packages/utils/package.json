{
  "name": "@repo/utils",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./fp": {
      "import": "./dist/fp/index.js",
      "types": "./dist/fp/index.d.ts"
    },
    "./common": {
      "import": "./dist/common/index.js",
      "types": "./dist/common/index.d.ts"
    },
    "./date": {
      "import": "./dist/common/date.js",
      "types": "./dist/common/date.d.ts"
    },
    "./string": {
      "import": "./dist/common/string.js",
      "types": "./dist/common/string.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "change-case": "^5.4.4",
    "date-fns": "^4.1.0",
    "fp-ts": "^2.16.9"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
