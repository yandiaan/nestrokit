{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":semanticCommitTypeAll(chore)"
  ],
  "schedule": ["before 5am on monday"],
  "timezone": "Asia/Jakarta",
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "rangeStrategy": "pin",
  "packageRules": [
    {
      "description": "Auto-merge patch updates for production dependencies",
      "matchUpdateTypes": ["patch"],
      "matchDepTypes": ["dependencies"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Auto-merge minor updates for dev dependencies",
      "matchUpdateTypes": ["minor", "patch"],
      "matchDepTypes": ["devDependencies"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Group all TypeScript related packages",
      "matchPackagePatterns": ["^typescript", "^@types/"],
      "groupName": "TypeScript"
    },
    {
      "description": "Group all NestJS packages",
      "matchPackagePatterns": ["^@nestjs/"],
      "groupName": "NestJS"
    },
    {
      "description": "Group all Astro packages",
      "matchPackagePatterns": ["^@astrojs/", "^astro"],
      "groupName": "Astro"
    },
    {
      "description": "Group all Svelte packages",
      "matchPackagePatterns": ["^svelte", "^@sveltejs/"],
      "groupName": "Svelte"
    },
    {
      "description": "Group all Prisma packages",
      "matchPackagePatterns": ["^prisma", "^@prisma/"],
      "groupName": "Prisma"
    },
    {
      "description": "Group all fp-ts packages",
      "matchPackagePatterns": ["^fp-ts"],
      "groupName": "fp-ts"
    },
    {
      "description": "Group all linting packages",
      "matchPackagePatterns": ["eslint", "prettier"],
      "groupName": "Linting"
    },
    {
      "description": "Require approval for major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["major-update", "needs-review"]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
